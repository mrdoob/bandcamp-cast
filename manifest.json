{
  "manifest_version": 3,
  "name": "Bandcamp Cast",
  "version": "1.1.0",
  "description": "Seamless Chromecast support for Bandcamp — cast albums to your TV or speakers with full play/pause/seek/skip sync.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.bandcamp.com/*"],
      "js": ["src/cast.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
